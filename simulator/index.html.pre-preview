  </div>
  <div class="sim-nav-pages" id="nav-pages">
    <!-- populated by JS -->
  </div>
</div>

<script>
  const screens = [
    { num: 1,  name: 'First run · welcome',      sprint: 'Sprint 5 · onboarding',          title: 'A new user opens Junior for the first time.', note: 'No account. No login. Just the brand mark, the promise, and one button. Either start free with your own key, or paste a license you bought from Whop.' },
    { num: 2,  name: 'Activate · key paste',     sprint: 'Sprint 5 · onboarding',          title: 'Paste an Anthropic key, or a license from Whop.', note: 'Free tier brings their own AI key. Paid users paste a Whop license that unlocks embedded keys, more videos, and publishing. Keys are encrypted via the OS keychain — never sent to Junior\'s servers.' },
    { num: 3,  name: 'Workspace · empty',        sprint: 'Sprint 4 · UI core',             title: 'The home screen. One drop zone, one promise.', note: 'This is the screen the user sees 95% of the time. Recent projects sit at the bottom — never block the drop zone. Status bar shows tier, unlimited counter, and platform connection state.' },
    { num: 4,  name: 'Workspace · hovering',     sprint: 'Sprint 4 · UI core',             title: 'A file is dragged over the drop zone.', note: 'The zone responds to drag-over with a fuchsia outline, the file preview floats above. Subtle but clear: "yes, you can drop this here." The "0s upload" promise gets reinforced inline.' },
    { num: 5,  name: 'Brief · context for AI',   sprint: 'Sprint 2 · pipeline',            title: 'Optional brief before processing starts.', note: 'After drop. Left pane shows what Junior already knows about the file. Right pane lets the user nudge the model. Skippable — Junior runs with sensible defaults if no brief. Memory hint (v1.2) plants the seed.' },
    { num: 6,  name: 'Working · stage 1',        sprint: 'Sprint 2 · pipeline',            title: 'Junior is working. Stage 3 of 9.', note: 'Past-tense for done stages, present verb for the active one, neutral for pending. Elapsed timer in italic Fraunces — the only large display element. The "0s upload time" tag stays visible. Cancel button lives in the chrome.' },
    { num: 7,  name: 'Working · stage 4',        sprint: 'Sprint 2 · pipeline',            title: 'Stage 7 of 9. Almost there.', note: 'Same screen, later. Done stages collapse visually. Active stage gets the page weight. Note how each completed stage gets a concrete number ("184,232 words", "22 moments scored 67–96") — specificity over vibes.' },
    { num: 8,  name: 'Results · clips grid',     sprint: 'Sprint 3 · output bundle',       title: '15 clips, ready to post. Scored 70 – 94.', note: 'Counter-Opus-Clip move: only show clips scored 70+. Quality over quantity. Tabs reveal the rest of the output bundle. Autopilot nudge below the grid — soft upsell, dismissible, fuchsia-tinted card.' },
    { num: 9,  name: 'Clip preview · edit',      sprint: 'Sprint 3 · output bundle',       title: 'Open a clip to preview, trim, or restyle.', note: 'Click any clip in the grid. Left pane: the actual clip in 9:16 with caption burned in. Right pane: source range editor, caption style picker, aspect ratio swap. Regenerate is destructive but cheap — runs stages 5–6 again on this clip only.' },
    { num: 10, name: 'Drip · setup',             sprint: 'Sprint 10 · drip mode',          title: 'Drip across 2 weeks. The killer feature.', note: 'The £149/mo moat. Left: duration picker + platform-by-platform schedule. Right: live 14-day calendar that updates as the user changes duration. Default: 2 weeks. Posts get auto-staggered per platform optimum (YT 6pm, TT 8pm).' },
    { num: 11, name: 'Drip · confirmation',      sprint: 'Sprint 10 · drip mode',          title: 'Queued. Junior posts while you sleep.', note: 'After confirm. Reinforces the moat copy directly: "Junior posts them on schedule even if you close this laptop." Bottom callout previews tomorrow\'s morning report — gives the user a reason to look forward to opening Junior the next day.' },
    { num: 12, name: 'Settings · one page',      sprint: 'Sprint 5 · onboarding · polish', title: 'One scrollable settings page. No nested screens.', note: 'Sidebar is anchor links, not separate pages. "Cancel via Whop →" link is deliberately prominent — direct refutation of Opus Clip\'s cancellation traps. Output folder shows the literal path the user can open in Finder.' },
  ];

  let currentScreen = 1;

  function buildNav() {
    const navEl = document.getElementById('nav-pages');
    navEl.innerHTML = '';
    screens.forEach(s => {
      const btn = document.createElement('button');
      btn.className = 'sim-nav-page';
      if (s.num === currentScreen) btn.classList.add('active');
      btn.textContent = String(s.num).padStart(2, '0') + ' · ' + s.name.replace('·', '—').split('—')[0].trim();
      btn.onclick = () => goToScreen(s.num);
      navEl.appendChild(btn);
    });
  }

  function goToScreen(n) {
    if (n < 1) n = screens.length;
    if (n > screens.length) n = 1;
    currentScreen = n;
    document.querySelectorAll('.screen').forEach(el => el.classList.remove('active'));
    const el = document.querySelector('[data-screen="' + n + '"]');
    if (el) el.classList.add('active');

    const s = screens[n - 1];
    document.getElementById('current-screen-num').textContent = String(n).padStart(2, '0');
    document.getElementById('screen-num').textContent = String(n).padStart(2, '0');
    document.getElementById('screen-name').textContent = s.name;
    document.getElementById('screen-sprint').textContent = s.sprint;
    document.getElementById('screen-title').textContent = s.title;
    document.getElementById('screen-note').textContent = s.note;

    document.querySelectorAll('.sim-nav-page').forEach((btn, i) => {
      btn.classList.toggle('active', i + 1 === n);
    });

    // Scroll active nav button into view
    const activeBtn = document.querySelector('.sim-nav-page.active');
    if (activeBtn) activeBtn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });

    // Scroll the app window into view
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function goNext() { goToScreen(currentScreen + 1); }
  function goPrev() { goToScreen(currentScreen - 1); }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') goNext();
    if (e.key === 'ArrowLeft') goPrev();
  });

  buildNav();
</script>


<script>
/* ============================================================
   SIMULATED INTERACTIVITY — every button does something
   ============================================================ */
(function() {
  // toast helper
  let toastEl = null;
  function toast(msg, ms=2200) {
    if (!toastEl) {
      toastEl = document.createElement('div');
      toastEl.className = 'toast';
      document.body.appendChild(toastEl);
    }
    toastEl.innerHTML = '<span class="toast-dot"></span>' + msg;
    toastEl.classList.add('show');
    clearTimeout(toast._t);
    toast._t = setTimeout(() => toastEl.classList.remove('show'), ms);
  }
  window._jnrToast = toast; // expose for debugging

  // chip + tab toggling via event delegation
  document.addEventListener('click', (e) => {
    const chip = e.target.closest('.brief-chip');
    if (chip && chip.parentElement && chip.parentElement.classList.contains('brief-chips')) {
      chip.parentElement.querySelectorAll('.brief-chip').forEach(c => c.classList.remove('selected'));
      chip.classList.add('selected');
      return;
    }
    const tab = e.target.closest('.results-tab');
    if (tab && tab.parentElement && tab.parentElement.classList.contains('results-tabs')) {
      tab.parentElement.querySelectorAll('.results-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const label = (tab.firstChild?.textContent || tab.textContent).trim();
      toast(`Switched to ${label}`);
      return;
    }
    const dur = e.target.closest('.drip-duration-option');
    if (dur && dur.parentElement && dur.parentElement.classList.contains('drip-duration')) {
      dur.parentElement.querySelectorAll('.drip-duration-option').forEach(o => o.classList.remove('selected'));
      dur.classList.add('selected');
      updateDripCalendar(dur);
      return;
    }
    const platform = e.target.closest('.drip-platform');
    if (platform) {
      platform.classList.toggle('off');
      const name = platform.querySelector('.drip-platform-name')?.textContent || 'platform';
      toast(platform.classList.contains('off') ? `${name} paused` : `${name} re-enabled`);
      return;
    }
  });

  // recent items → open results
  document.querySelectorAll('.recent-item').forEach(item => {
    item.addEventListener('click', () => {
      toast('Reopening project');
      setTimeout(() => goToScreen(8), 320);
    });
  });

  // drop zone simulation
  const dz = document.getElementById('dropzone-3');
  if (dz) {
    dz.onclick = null;
    dz.addEventListener('click', () => {
      dz.classList.add('dropping');
      setTimeout(() => goToScreen(4), 380);
      setTimeout(() => {
        dz.classList.remove('dropping');
        goToScreen(5);
      }, 1300);
    });
  }
  const screen4 = document.querySelector('[data-screen="4"]');
  if (screen4) {
    screen4.addEventListener('click', (e) => {
      if (e.target.closest('button,a,input,select,textarea')) return;
      goToScreen(5);
    });
  }

  // working state animation
  let lastScreen = 1;
  let workingTimers = [];
  function clearWorkingTimers() { workingTimers.forEach(clearTimeout); workingTimers = []; }
  function tickTimer(el, fromSec, toSec, durationMs) {
    if (!el) return;
    const start = performance.now();
    function step(now) {
      const t = Math.min(1, (now - start) / durationMs);
      const cur = Math.round(fromSec + (toSec - fromSec) * t);
      const m = Math.floor(cur / 60), s = cur % 60;
      el.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
      if (t < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const screenObs = new MutationObserver(muts => {
    muts.forEach(m => {
      if (m.attributeName !== 'class') return;
      const el = m.target;
      if (!el.classList.contains('active')) return;
      const num = parseInt(el.dataset.screen, 10);
      if (num === 6 && lastScreen === 5) {
        clearWorkingTimers();
        const t1 = el.querySelector('.working-timer-value');
        tickTimer(t1, 107, 218, 2800);
        workingTimers.push(setTimeout(() => { if (currentScreen === 6) goToScreen(7); }, 2900));
        workingTimers.push(setTimeout(() => {
          if (currentScreen !== 7) return;
          const t2 = document.querySelector('[data-screen="7"] .working-timer-value');
          tickTimer(t2, 218, 318, 2500);
        }, 3000));
        workingTimers.push(setTimeout(() => { if (currentScreen === 7) goToScreen(8); }, 5800));
      }
      if (num !== 6 && num !== 7) clearWorkingTimers();
      // Pause/play featured preview on enter/leave screen 9
      if (num === 9) {
        const v = document.querySelector('.preview-video-el');
        if (v) { v.currentTime = 0; v.play().catch(() => {}); }
      }
      lastScreen = num;
    });
  });
  document.querySelectorAll('.screen').forEach(s => {
    screenObs.observe(s, { attributes: true, attributeFilter: ['class'] });
  });

  // preview modal buttons
  document.querySelectorAll('[data-screen="9"] .btn').forEach(btn => {
    const text = btn.textContent.trim().toLowerCase();
    if (text.startsWith('regenerate')) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (btn.dataset.busy) return;
        btn.dataset.busy = '1';
        const orig = btn.textContent;
        btn.innerHTML = '<span class="spinner"></span>Regenerating';
        const v = document.querySelector('.preview-video-el');
        if (v) { try { v.currentTime = 0; v.play().catch(() => {}); } catch(_) {} }
        setTimeout(() => {
          btn.textContent = orig;
          delete btn.dataset.busy;
          toast('Clip regenerated · new framing applied');
        }, 1700);
      });
    } else if (text.startsWith('save changes')) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        toast('Saved');
        setTimeout(() => goToScreen(8), 280);
      });
    }
  });

  // results action buttons
  document.querySelectorAll('[data-screen="8"] .results-actions .btn, [data-screen="8"] .results-actions button').forEach(btn => {
    const text = btn.textContent.trim().toLowerCase();
    if (text === 'open folder') {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        toast('~/Junior/projects/podcast-ep-47/  · Opened in Finder');
      });
    } else if (text === 'publish now') {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        toast('Pick a clip first, then publish');
      });
    }
  });

  // drip calendar live update
  function updateDripCalendar(durEl) {
    if (!durEl) return;
    const label = durEl.querySelector('.drip-duration-label')?.textContent.trim() || '';
    const days = label.startsWith('1') ? 7 : label.startsWith('2') ? 14 : label.startsWith('3') ? 21 : 28;
    const meta = document.querySelector('.drip-calendar-meta');
    const calTitle = document.querySelector('.drip-calendar-title');
    const titleEm = document.querySelector('.drip-title em');
    if (meta) meta.textContent = `${days} days · 15 posts`;
    if (calTitle) calTitle.textContent = `Episode 47 — drip across ${label}`;
    if (titleEm) titleEm.textContent = `${label}.`;
    toast(`Drip set to ${label}`);
  }

  // drip schedule button
  document.querySelectorAll('[data-screen="10"] .btn').forEach(btn => {
    const text = btn.textContent.trim().toLowerCase();
    if (text.includes('schedule') || text.includes('confirm') || text.startsWith('queue')) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (btn.dataset.busy) return;
        btn.dataset.busy = '1';
        const orig = btn.innerHTML;
        btn.innerHTML = '<span class="spinner"></span>Scheduling 15 clips';
        setTimeout(() => {
          btn.innerHTML = orig;
          delete btn.dataset.busy;
          toast('15 clips scheduled across 14 days');
          goToScreen(11);
        }, 1400);
      });
    }
  });

  // settings toggles
  document.querySelectorAll('[data-screen="12"] .settings-pill').forEach(p => {
    p.style.cursor = 'pointer';
    p.addEventListener('click', () => {
      const group = p.parentElement;
      if (group) {
        group.querySelectorAll('.settings-pill').forEach(pp => pp.classList.remove('active'));
        p.classList.add('active');
      } else {
        p.classList.toggle('active');
      }
      toast(`Set to ${p.textContent.trim()}`);
    });
  });

  // first-run demo video click → toggle mute
  document.querySelectorAll('.first-run-demo-video').forEach(v => {
    v.addEventListener('click', () => {
      v.muted = !v.muted;
      try { v.play(); } catch(_) {}
      toast(v.muted ? 'Muted' : "Sound on — that's your clip");
    });
  });

  // force-play all videos on first user gesture (mobile autoplay safety net)
  let firstGestureHandled = false;
  function kickAllVideos() {
    if (firstGestureHandled) return;
    firstGestureHandled = true;
    document.querySelectorAll('video').forEach(v => {
      try { v.play().catch(() => {}); } catch(_) {}
    });
  }
  ['click','touchstart','keydown','scroll'].forEach(ev => {
    document.addEventListener(ev, kickAllVideos, { once: true, passive: true });
  });

  // screen 2: paste field auto-fills on focus
  document.querySelectorAll('[data-screen="2"] input').forEach(input => {
    input.addEventListener('focus', () => {
      if (!input.value) {
        input.value = 'sk-ant-' + 'x'.repeat(40);
        input.dispatchEvent(new Event('input'));
        setTimeout(() => toast('Key validated · all systems good'), 600);
      }
    });
  });

  // IntersectionObserver: pause off-screen clip videos
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        const v = e.target;
        if (e.isIntersecting) { v.play().catch(() => {}); }
        else { v.pause(); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.clip-thumb-video').forEach(v => io.observe(v));
  }
})();
</script>

</body>
</html>
