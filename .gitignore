# Junior mono-repo — root gitignore. Per-project .gitignores layer on top.
# This file's job is the universal stuff: secrets, build artefacts, OS dust.

# --- Secrets (NEVER commit) -------------------------------------------------
.env
.env.*
!.env.example
*.env
!*.env.example
.envrc
env.md
ENV.md
*.env.md

# Keychain / credentials stores from this machine that may exist alongside.
.claude-credentials/
.claude/

# License signing keys generated locally on first backend boot.
.junior-keys/

# --- Node / Vite ------------------------------------------------------------
node_modules/
dist/
build/
.next/
.turbo/
out/
.vercel/
*.tsbuildinfo

# --- Rust / Tauri (the 11 GB beast) -----------------------------------------
target/
**/src-tauri/gen/

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- ML models bundled at build time (75 MB faster-whisper) -----------------
# Pull these from the build script — don't commit the binaries.
desktop/python-sidecar/models/
desktop/python-sidecar/bin/ffmpeg
desktop/python-sidecar/bin/ffprobe

# --- Tauri build outputs ----------------------------------------------------
*.dmg
*.app.tar.gz
*.app.tar.gz.sig

# --- IDE / OS noise ---------------------------------------------------------
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
Thumbs.db

# --- Local logs + sqlite ----------------------------------------------------
*.log
*.sqlite
*.sqlite3
*.db

# --- Project-specific local state -------------------------------------------
junior-backend/junior.db
junior-backend/.junior-keys/

# Cache from the desktop's user-data area in case anyone symlinks it in.
desktop/.cache/

# v0.7.32 — macOS Finder / Dropbox duplicate artifacts (" 2.<ext>" suffix).
# Don't track these — they're sync conflicts, not source.
* 2.png
* 2.jpg
* 2.mp4
* 2.md
* 2.txt
* 2.tsx
* 2.ts
* 2.py
* 2.css
* 2.html
* 2.json
* 2.sh

# Local impeccable skill installation (not source code)
desktop/.agents/

# Build / sign-clean working dir
desktop/dist/
desktop/src-tauri/target/
desktop/skills-lock.json

# v0.7.32 — wider gitignore expansion to unblock ship.sh
desktop/src/_backups/
assets-wip/
desktop/src/assets/decks/*[0-9].png
desktop/src/assets/decks/minecraft-submission*.png
desktop/src/assets/intro/oasis-anchor*.png
desktop/src/assets/invaders/_backup/
desktop/src/assets/nav-badges/
desktop/src/assets/nav-icons/
LAUNCH 2.md
* 3.py
* 3.md
* 3.txt
* 3.tsx

# Sibling working dirs (separate Codex / Powstit / marketing-asset clones).
# Live next to desktop/ in the repo root but aren't part of the main app.
/jnr-codex-launch/
/jnr-powstit/
/liquid-clips-assets/
/liquidclips-marketing/

# Motion-graphics intermediates + unused gpt-image-1 variants.
desktop/src/assets/bug-3d/*.b64
desktop/src/assets/bug-3d/fuchsia-beetle.png
