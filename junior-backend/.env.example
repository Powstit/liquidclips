# Liquid Clips Backend env vars. Copy to .env locally; set in Railway dashboard for prod.

# Server port — Railway sets PORT automatically; ignore locally.
PORT=8000

# Database. Local SQLite by default; Railway sets DATABASE_URL to its managed
# Postgres connection string.
DATABASE_URL=sqlite:///./junior-backend.db

# Clerk webhook secret (svix) — set after creating the webhook in Clerk dashboard.
CLERK_WEBHOOK_SECRET=

# Whop — webhook secret + API key for outbound calls (mirror affiliates, etc.).
WHOP_WEBHOOK_SECRET=
WHOP_API_KEY=
WHOP_COMPANY_ID=biz_0IMrpJRrTJID1u
WHOP_APP_ID=app_hLphExdFzjEQsM

# License JWT — Ed25519 PEM-encoded keypair. Leave blank locally; auto-generated
# on first boot into .junior-keys/. In production, generate once, paste both
# values here, then commit ONLY the public PEM to the desktop bundle.
JWT_PRIVATE_PEM=
JWT_PUBLIC_PEM=
JWT_ISSUER=junior-backend
JWT_TTL_DAYS=30

# LLM provider keys for the /proxy/llm endpoint (Pro/Agency tiers).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ayrshare — P1 social publishing backend (Business plan, $599/mo, 30 profiles).
# Single org-wide key; per-user profile keys are pasted in by users via Settings
# → Connections and stored in social_connections.ayrshare_profile_key.
# When unset, /publish-now returns 503 "beta" and features.publish_now reports
# built=false, so the desktop publishing surface degrades cleanly instead of
# silently stubbing.
AYRSHARE_API_KEY=

# Comma-separated allowed origins for CORS. The tauri:// + tauri.localhost
# origins are the packaged desktop webview (macOS uses tauri://localhost,
# Windows/Linux http(s)://tauri.localhost) — required or browser-side packaged
# calls (e.g. notifications) fail the CORS preflight. Keep these in any prod list.
CORS_ORIGINS=http://localhost:3000,http://localhost:3500,http://localhost:1420,https://account.jnremployee.com,https://account.jnremployee.com,https://liquidclips.app,tauri://localhost,https://tauri.localhost,http://tauri.localhost
