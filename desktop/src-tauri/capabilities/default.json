{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Liquid Clips desktop window",
  "windows": ["main", "browse_panel", "social_link", "auth_panel"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:event:default",
    "core:webview:default",
    "core:path:default",
    "dialog:default",
    "fs:default",
    "fs:allow-appdata-write-recursive",
    "fs:allow-appdata-meta-recursive",
    "shell:default",
    "shell:allow-open",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "updater:default",
    "process:default",
    "deep-link:default"
  ]
}
