{
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "https://account.jnremployee.com/dashboard",
      "permanent": false
    },
    {
      "source": "/dashboard/:path*",
      "destination": "https://account.jnremployee.com/dashboard/:path*",
      "permanent": false
    },
    {
      "source": "/sign-in",
      "destination": "https://account.jnremployee.com/sign-in",
      "permanent": false
    },
    {
      "source": "/sign-up",
      "destination": "https://account.jnremployee.com/sign-up",
      "permanent": false
    },
    {
      "source": "/upgrade",
      "destination": "https://account.jnremployee.com/upgrade",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "https://account.jnremployee.com/sign-in",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none'" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
