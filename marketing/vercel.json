{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "jnremployee.com" }],
      "destination": "https://liquidclips.app/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.jnremployee.com" }],
      "destination": "https://liquidclips.app/$1",
      "permanent": true
    },
    {
      "source": "/affiliate",
      "destination": "/affiliates",
      "permanent": false
    },
    {
      "source": "/dashboard",
      "destination": "https://account.liquidclips.app/dashboard",
      "permanent": false
    },
    {
      "source": "/dashboard/:path*",
      "destination": "https://account.liquidclips.app/dashboard/:path*",
      "permanent": false
    },
    {
      "source": "/sign-in",
      "destination": "https://account.liquidclips.app/sign-in",
      "permanent": false
    },
    {
      "source": "/sign-up",
      "destination": "https://account.liquidclips.app/sign-up",
      "permanent": false
    },
    {
      "source": "/upgrade",
      "destination": "https://account.liquidclips.app/upgrade",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "https://account.liquidclips.app/sign-in",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none'" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
